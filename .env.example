# ── Supabase ─────────────────────────────────────────────────────────────────
# Récupérer depuis https://app.supabase.com → Settings → API
VITE_SUPABASE_URL="https://xxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJxxx"

# ── AI API keys (server-side only — Supabase Edge Functions secrets) ──────────
# Ces clés NE doivent JAMAIS avoir le préfixe VITE_ : elles resteront côté serveur.
# Les définir via : supabase secrets set OPENROUTER_API_KEY=sk-or-...
#
# OpenRouter — embeddings & LLM (https://openrouter.ai/keys)
OPENROUTER_API_KEY="sk-or-..."
# Gemini Live API — conseiller vocal temps réel (https://aistudio.google.com/apikey)
GEMINI_API_KEY="AIza..."

# ── AI embedding config (build-time, no secrets) ─────────────────────────────
# IMPORTANT: ces valeurs DOIVENT correspondre à la colonne vector(N) en DB.
# La DB utilise vector(3072) — ne pas changer sans re-générer tous les embeddings.
VITE_OPENROUTER_EMBED_MODEL="openai/text-embedding-3-large"
VITE_OPENROUTER_EMBED_DIMENSIONS="3072"

# ── Stripe ────────────────────────────────────────────────────────────────────
# Clé publique (client side — préfixe VITE_ obligatoire)
VITE_STRIPE_PUBLIC_KEY="pk_test_..."
# Clé secrète (Edge Functions uniquement — NE PAS préfixer VITE_)
# Configurer via : npx supabase secrets set STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret — obtenu dans le dashboard Stripe > Webhooks
# Configurer via : npx supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_SECRET="whsec_..."
  
# ── Misc ──────────────────────────────────────────────────────────────────────
APP_URL="https://your-app.vercel.app"

# Monitoring frontend (optionnel)
VITE_SENTRY_DSN=""
